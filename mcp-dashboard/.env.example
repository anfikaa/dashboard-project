APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
SCAN_SOURCE=local
SCAN_LOCAL_PATH=app/scan
SCAN_S3_DISK=s3
SCAN_S3_PREFIX=result
SCAN_S3_MAX_FILES=5
SCAN_S3_MAX_FILES_PER_TOOL=1
SCAN_S3_PAGE_SIZE=50
SCAN_S3_INDEX_CACHE_TTL_SECONDS=300
SCAN_CACHE_TTL_SECONDS=300
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_PROFILE=default
AWS_DEFAULT_REGION=ap-southeast-3
AWS_BUCKET=
AWS_ENDPOINT=https://s3.ap-southeast-3.amazonaws.com
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_CREDENTIAL_DEBUG=false
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_FILESYSTEM_THROW=true
AWS_FILESYSTEM_REPORT=true
AWS_DYNAMODB_TABLE=
AWS_DYNAMODB_REGION=
AWS_DYNAMODB_ENDPOINT=

CLUSTER_AGENT_DYNAMODB_TABLE=intern_cluster_register
SECURITY_TASKS_DYNAMODB_TABLE=intern-tasks
SECURITY_AGENT_BASE_URL=
SECURITY_TASK_HTTP_TIMEOUT_SECONDS=30
SECURITY_TASK_HTTP_CONNECT_TIMEOUT_SECONDS=10
SECURITY_TASK_HEALTHCHECK_TIMEOUT_SECONDS=20
SECURITY_TASK_HEALTHCHECK_CONNECT_TIMEOUT_SECONDS=5
SECURITY_TASK_LOG_LEVEL=debug
SECURITY_TASK_LOG_DAYS=14

VITE_APP_NAME="${APP_NAME}"
